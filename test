-- PRIVATE SERVER DETECTION
local function isPrivateServer()
    return #Players:GetPlayers() <= 1
end

local function updateWarnButton()
    if isPrivateServer() then
        WarnButton.TextColor3 = Color3.fromRGB(255, 80, 80)
        WarnButton.BackgroundColor3 = Color3.fromRGB(60, 20, 35)
    else
        WarnButton.TextColor3 = Color3.fromRGB(255, 210, 80)
        WarnButton.BackgroundColor3 = Color3.fromRGB(50, 20, 65)
    end
end

